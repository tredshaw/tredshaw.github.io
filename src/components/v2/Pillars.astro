---
// Pillars.astro — v2 four pillars (frost glass treatment via body[data-pillar="frost"])
// Copy comes from src/data/copy.json; icons + card classes stay fixed here.
import copy from "@data/copy.json";
const { pillars } = copy;
const icons = ["/anxiety_icon.png", "/support_icon.png", "/progress_icon.png", "/joy_icon.png"];
---

<section class="sec" id="pillars">
  <div class="wrap">
    <div class="sec-head" data-reveal>
      <span class="eyebrow"><span class="pip"></span> {pillars.eyebrow}</span>
      <h2 set:html={pillars.heading}></h2>
      <p>{pillars.intro}</p>
    </div>
    <div class="pillars">
      {pillars.items.map((p, i) => (
        <article class={`pillar p${i + 1}`} data-reveal data-reveal-d={String(i)}>
          <img class="ico" src={icons[i]} alt="" />
          <h3>{p.title}</h3>
          <p>{p.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>
