---
// Hero.astro — v2 hero with toggleable dark/light background + inline Mailchimp capture
import copy from "@data/copy.json";
const { hero } = copy;
---

<header class="hero" id="top">
  <div class="caustic c1"></div><div class="caustic c2"></div><div class="caustic c3"></div>
  <div class="wrap hero-grid">
    <div>
      <span class="eyebrow" data-h="0"><span class="pip"></span> {hero.eyebrow}</span>
      <h1 id="heroHeadline" data-h="1" set:html={hero.headlineA}></h1>
      <p class="sub" id="heroSub" data-h="2">{hero.subA}</p>
      <div class="capture" data-h="3">
        <form id="heroForm" novalidate>
          <input type="hidden" name="u" value="e030f7d989712f6a3a269d158" />
          <input type="hidden" name="id" value="303ad0aa59" />
          <input type="hidden" name="f_id" value="00a136e7f0" />
          <input class="mc-hp" type="text" name="b_e030f7d989712f6a3a269d158_303ad0aa59" tabindex="-1" value="" aria-hidden="true" autocomplete="off" />
          <input type="email" id="heroEmail" name="EMAIL" placeholder={hero.emailPlaceholder} aria-label="Email address" autocomplete="email" required />
          <button type="submit" class="btn">{hero.cta} <span class="arr">→</span></button>
        </form>
        <p class="done" id="heroDone"></p>
      </div>
      <div class="proof" data-h="4">
        <div class="avatars" aria-hidden="true">
          <span style="background:linear-gradient(135deg,#30E6F8,#105F80)"></span>
          <span style="background:linear-gradient(135deg,#62EEFA,#23C2D2)"></span>
          <span style="background:linear-gradient(135deg,#FF6B6B,#F3A38F)"></span>
          <span style="background:linear-gradient(135deg,#105F80,#07425B)"></span>
        </div>
        <span>{hero.proof}</span>
      </div>
      <div class="hero-trust" data-h="4"><span class="dot"></span> {hero.trust}</div>
    </div>
    <div class="hero-art" data-h="5">
      <img class="sw sw-open" src="/hero_swimmer.png" alt="Illustration of a calm swimmer" />
    </div>
  </div>
</header>
