---
// EmailCapture.astro — v2 email capture with Mailchimp JSONP
---

<section id="email-capture">
  <div class="wrap">
    <div class="cta-band">
      <h2>Ready to find your flow?</h2>
      <p>Join the calm. Be the first to swim with Eddy when we open the next group.</p>

      <form id="mc-form" novalidate>
        <input type="hidden" name="u" value="e030f7d989712f6a3a269d158" />
        <input type="hidden" name="id" value="303ad0aa59" />
        <input type="hidden" name="f_id" value="00a136e7f0" />
        <!-- bot honeypot -->
        <input type="text" name="b_e030f7d989712f6a3a269d158_303ad0aa59" tabindex="-1" value="" style="position:absolute;left:-5000px;" aria-hidden="true" />
        <div class="waitlist">
          <input type="email" id="mc-email" name="EMAIL" required placeholder="your@email.com" autocomplete="email" />
          <button type="submit">Join the waitlist</button>
        </div>
      </form>

      <div id="mc-success" class="feedback success" hidden>
        You're in — we'll be in touch, calmly.
      </div>
      <div id="mc-error" class="feedback error" hidden>
        Something went wrong. Please try again.
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding: 80px 0;
    background: #FAF6F0;
  }
  .wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 28px;
  }
  .cta-band {
    background: linear-gradient(135deg, #105F80 0%, #07425B 100%);
    color: #fff;
    border-radius: 24px;
    padding: 72px 64px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-band::after {
    content: "";
    position: absolute;
    right: -50px;
    top: -50px;
    width: 260px;
    height: 260px;
    background: radial-gradient(circle, rgba(48,230,248,0.22) 0%, transparent 70%);
    pointer-events: none;
  }
  h2 {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin: 0;
    position: relative;
  }
  p {
    font-size: 1.05rem;
    margin: 16px auto 0;
    max-width: 480px;
    opacity: 0.88;
    position: relative;
  }
  .waitlist {
    display: flex;
    gap: 10px;
    max-width: 440px;
    margin: 30px auto 0;
    position: relative;
  }
  .waitlist input[type="email"] {
    flex: 1;
    font-family: 'Figtree', system-ui, sans-serif;
    font-size: 15px;
    padding: 14px 18px;
    border-radius: 9999px;
    border: none;
    outline: none;
    color: #16201F;
    background: #fff;
  }
  .waitlist input[type="email"]::placeholder { color: #6B8085; }
  .waitlist input[type="email"]:focus {
    box-shadow: 0 0 0 3px rgba(48,230,248,0.4);
  }
  .waitlist button {
    font-family: 'Figtree', system-ui, sans-serif;
    font-weight: 600;
    font-size: 15px;
    padding: 14px 24px;
    border-radius: 9999px;
    border: none;
    background: #30E6F8;
    color: #07425B;
    cursor: pointer;
    white-space: nowrap;
    transition: background 200ms ease;
  }
  .waitlist button:hover { background: #23C2D2; }
  .feedback {
    margin-top: 22px;
    font-size: 16px;
    font-weight: 500;
    position: relative;
  }
  .success { color: #30E6F8; }
  .error { color: #FF6B6B; }

  @media (max-width: 640px) {
    .cta-band { padding: 48px 28px; }
    .waitlist { flex-direction: column; }
    .waitlist button { width: 100%; justify-content: center; }
  }
</style>

<script is:inline>
  document.getElementById('mc-form').addEventListener('submit', function (e) {
    e.preventDefault();
    var email = document.getElementById('mc-email').value.trim();
    if (!email) return;

    var params = new URLSearchParams({
      u: 'e030f7d989712f6a3a269d158',
      id: '303ad0aa59',
      f_id: '00a136e7f0',
      EMAIL: email,
      b_e030f7d989712f6a3a269d158_303ad0aa59: '',
      c: 'mcCallback',
    });

    window.mcCallback = function (data) {
      var ok = data && data.result === 'success';
      document.getElementById('mc-success').hidden = !ok;
      document.getElementById('mc-error').hidden = ok;
      if (ok) document.getElementById('mc-form').hidden = true;
      delete window.mcCallback;
    };

    var s = document.createElement('script');
    s.src = 'https://swimwitheddy.us19.list-manage.com/subscribe/post-json?' + params.toString();

    var fallback = setTimeout(function () {
      if (window.mcCallback) {
        document.getElementById('mc-success').textContent = 'Request sent — check your inbox shortly.';
        document.getElementById('mc-success').hidden = false;
        document.getElementById('mc-form').hidden = true;
        delete window.mcCallback;
        s.remove();
      }
    }, 5000);

    s.onload = function () { clearTimeout(fallback); s.remove(); };
    s.onerror = function () {
      clearTimeout(fallback);
      document.getElementById('mc-error').hidden = false;
      delete window.mcCallback;
      s.remove();
    };
    document.head.appendChild(s);
  });
</script>
