---
// Testimonials.astro — v2 testimonials
const quotes = [
  { q: "I hadn't put my face in the water for thirty years. Eddy got me there in three weeks — calmly.", who: "Priya", role: "Learned to swim at 41" },
  { q: "It never once made me feel silly for being scared. That's why it worked.", who: "Marcus", role: "Open-water beginner" },
  { q: "The confidence tracker is the first time I've seen my own progress. I cried, a little.", who: "Janette", role: "Returning swimmer" },
];
---

<section id="testimonials">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">What our swimmers say</span>
      <h2>Quietly life-changing.</h2>
    </div>

    <div class="quote-card">
      {quotes.map((t, i) => (
        <div class="slide" data-index={i} aria-hidden={i !== 0 ? "true" : "false"}>
          <blockquote class="q">&ldquo;{t.q}&rdquo;</blockquote>
          <p class="who"><b>{t.who}</b> · {t.role}</p>
        </div>
      ))}
      <div class="dots">
        {quotes.map((_, i) => (
          <button class="dot" data-target={i} aria-label={`Story ${i + 1}`} aria-selected={i === 0 ? "true" : "false"} />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding: 92px 0;
    background: #FAF6F0;
  }
  .wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 28px;
  }
  .sec-head {
    text-align: center;
    margin-bottom: 44px;
  }
  .eyebrow {
    display: block;
    font-family: 'Figtree', system-ui, sans-serif;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #105F80;
    margin-bottom: 14px;
  }
  h2 {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    letter-spacing: -0.02em;
    color: #16201F;
    margin: 0;
  }
  .quote-card {
    background: #fff;
    border: 1px solid #EADFCF;
    border-radius: 24px;
    padding: 52px 56px;
    box-shadow: 0 4px 20px rgba(16,95,128,0.08);
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .slide { display: block; }
  .slide.is-hidden { display: none; }
  .q {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 500;
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    line-height: 1.45;
    letter-spacing: -0.01em;
    color: #16201F;
    margin: 0 0 22px;
  }
  .who {
    font-size: 15px;
    color: #6B8085;
    margin: 0;
  }
  .who b {
    color: #16201F;
    font-weight: 600;
  }
  .dots {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: 28px;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    border: none;
    background: #DECFBA;
    cursor: pointer;
    padding: 0;
    transition: all 280ms cubic-bezier(.22,.61,.36,1);
  }
  .dot.is-active {
    background: #105F80;
    width: 24px;
  }
  @media (max-width: 640px) {
    .quote-card { padding: 36px 24px; }
  }
</style>

<script is:inline>
  (function () {
    var slides = document.querySelectorAll('.slide');
    var dots = document.querySelectorAll('.dot');
    if (!slides.length) return;
    function goTo(n) {
      slides.forEach(function (s, i) {
        s.classList.toggle('is-hidden', i !== n);
        s.setAttribute('aria-hidden', i !== n ? 'true' : 'false');
      });
      dots.forEach(function (d, i) {
        d.classList.toggle('is-active', i === n);
        d.setAttribute('aria-selected', i === n ? 'true' : 'false');
      });
    }
    goTo(0);
    dots.forEach(function (d) {
      d.addEventListener('click', function () { goTo(parseInt(d.dataset.target, 10)); });
    });
  })();
</script>
