---
// Footer.astro — v2 footer (design-faithful)
import copy from "@data/copy.json";
const { footer, nav } = copy;
const year = new Date().getFullYear();
---

<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <a href="/#top" class="brand"><span class="mark"><img src="/logo.png" alt="" /></span><span class="name">{nav.brand}</span></a>
        <p>{footer.brandDesc}</p>
      </div>
      <div class="foot-cols">
        {footer.columns.map((col) => (
          <div class="foot-col">
            <h5>{col.heading}</h5>
            {col.links.map((l) => <a href={l.href}>{l.label}</a>)}
          </div>
        ))}
      </div>
    </div>
    <div class="foot-base"><span>© {year} {footer.copyright}</span><span>{footer.contactEmail}</span></div>
  </div>
</footer>
