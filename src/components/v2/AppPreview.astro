---
// AppPreview.astro — v2 app preview section
const features = [
  {
    title: "A plan that adapts to you",
    desc: "Your week, paced to your confidence — never the other way around.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  },
  {
    title: "Progress you can feel",
    desc: "Distance, confidence and sessions, tracked with kind, clear nudges.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
  {
    title: "Wellness check-ins",
    desc: "Notice how each swim leaves you feeling, and let Eddy adjust.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
];
---

<section id="app-preview" class="band">
  <div class="wrap appshow">
    <!-- Phone -->
    <div class="phone">
      <img src="/your_week.png" alt="Eddy app showing your weekly swim plan" loading="lazy" />
    </div>
    <!-- Copy -->
    <div class="copy">
      <span class="eyebrow">In your pocket</span>
      <h2>Your week, made calm.</h2>
      <ul class="feat-list">
        {features.map((f) => (
          <li class="feat">
            <span class="dot" set:html={f.icon} />
            <div>
              <h4>{f.title}</h4>
              <p>{f.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .band { background: #F0EBE3; }
  .wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 28px;
  }
  .appshow {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    padding: 92px 0;
  }
  .phone {
    display: flex;
    justify-content: center;
  }
  .phone img {
    width: 100%;
    max-width: 300px;
    filter: drop-shadow(0 30px 60px rgba(10,49,71,.24));
    border-radius: 28px;
  }
  .eyebrow {
    display: block;
    font-family: 'Figtree', system-ui, sans-serif;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #105F80;
    margin-bottom: 14px;
  }
  h2 {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    letter-spacing: -0.02em;
    color: #16201F;
    margin: 0;
  }
  .feat-list {
    list-style: none;
    padding: 0;
    margin: 28px 0 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .feat {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .dot {
    flex: none;
    width: 32px;
    height: 32px;
    border-radius: 9px;
    background: rgba(48,230,248,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #105F80;
    margin-top: 1px;
  }
  h4 {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 600;
    font-size: 1rem;
    color: #16201F;
    margin: 0 0 4px;
  }
  p {
    font-size: 14px;
    line-height: 1.55;
    color: #42585C;
    margin: 0;
  }
  @media (max-width: 860px) {
    .appshow { grid-template-columns: 1fr; gap: 40px; padding: 60px 0; }
    .phone { order: 2; }
    .copy { order: 1; }
  }
</style>
