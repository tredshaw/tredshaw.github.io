---
// AppPreview.astro — v2 app preview section
const features = [
  {
    title: "A plan that adapts to you",
    description: "Your week, paced to your confidence — never the other way around.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  },
  {
    title: "Progress you can feel",
    description: "Distance, confidence and sessions, tracked with kind, clear nudges.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  },
  {
    title: "Wellness check-ins",
    description: "Notice how each swim leaves you feeling, and let Eddy adjust.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  },
];
---

<section id="app-preview" class="bg-base py-16 sm:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <!-- App screenshot -->
    <div class="flex justify-center md:justify-start order-2 md:order-1">
      <img
        src="/your_week.png"
        alt="Eddy app showing your week's session plan"
        class="max-w-xs sm:max-w-sm w-full object-contain drop-shadow-xl"
        loading="lazy"
      />
    </div>

    <!-- Copy -->
    <div class="order-1 md:order-2">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-fg2 mb-4">
        In your pocket
      </p>
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-text mb-8">
        Your week, made calm.
      </h2>
      <ul class="flex flex-col gap-6 list-none p-0 m-0">
        {features.map((feature) => (
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 mt-0.5 text-aqua" set:html={feature.icon} />
            <div>
              <p class="font-semibold text-text mb-1">{feature.title}</p>
              <p class="text-fg2 text-sm leading-relaxed">{feature.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
