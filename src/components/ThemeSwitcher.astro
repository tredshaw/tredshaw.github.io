---
// No props — reads/writes localStorage key 'eddy-theme'
---

<div id="theme-switcher">
  <span class="label">Theme</span>
  <button data-theme-btn="v1">V1</button>
  <button data-theme-btn="v2">V2</button>
  <button data-theme-btn="v3">V3</button>
  <button data-theme-btn="v4">V4</button>
  <button data-theme-btn="v5">V5</button>
</div>

<style>
  #theme-switcher {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    border: 1px solid #d1d5db;
    border-radius: 0.75rem;
    padding: 0.5rem 0.625rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.13);
    font-family: system-ui, sans-serif;
  }

  #theme-switcher .label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
    margin-right: 0.25rem;
  }

  #theme-switcher button {
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    border: 2px solid transparent;
    background: #f3f4f6;
    font-size: 0.7rem;
    font-weight: 700;
    color: #374151;
    cursor: pointer;
    transition: background 120ms, border-color 120ms, color 120ms;
    line-height: 1;
  }

  #theme-switcher button:hover {
    background: #e5e7eb;
  }

  #theme-switcher button.active {
    border-color: #105F80;
    background: #dbeafe;
    color: #0A4C66;
  }
</style>

<script>
  const STORAGE_KEY = 'eddy-theme';
  const root = document.documentElement;
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-btn]');

  function setTheme(theme: string) {
    root.setAttribute('data-theme', theme);
    localStorage.setItem(STORAGE_KEY, theme);
    buttons.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.themeBtn === theme);
    });
  }

  const current = root.getAttribute('data-theme') || 'v1';
  setTheme(current);

  buttons.forEach(btn => {
    btn.addEventListener('click', () => setTheme(btn.dataset.themeBtn!));
  });
</script>
