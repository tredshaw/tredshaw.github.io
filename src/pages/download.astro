---
import Layout from "@layouts/Layout.astro";
---

<Layout title="Download Eddy">
  <main class="min-h-screen bg-base flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <h1 class="text-4xl font-bold text-primary mb-4">Coming soon</h1>
      <p class="text-text/70 text-lg">
        The Eddy app is on its way. Join the waitlist on the <a href="/#email-capture" class="text-primary underline underline-offset-2">home page</a> to be first to know.
      </p>
    </div>
  </main>
</Layout>
